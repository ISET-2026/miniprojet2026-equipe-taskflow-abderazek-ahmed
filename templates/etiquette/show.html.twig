{% extends 'base.html.twig' %}

{% block title %}{{ etiquette.nom }} - TaskFlow{% endblock %}

{% block body %}
<div class="space-y-6">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-slate-900"><i class="bi bi-tag text-blue-600 mr-2"></i>{{ etiquette.nom }}</h1>
        </div>
        <div class="flex items-center gap-3">
            <a href="{{ path('etiquette_edit', {id: etiquette.id}) }}" class="inline-flex items-center rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                <i class="bi bi-pencil mr-2"></i> Modifier
            </a>
            <form method="post" action="{{ path('etiquette_delete', {id: etiquette.id}) }}" data-confirm data-confirm-message="Supprimer cette étiquette ?">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ etiquette.id) }}">
                <button type="submit" class="inline-flex items-center rounded-full bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 transition hover:bg-red-100">
                    <i class="bi bi-trash mr-2"></i> Supprimer
                </button>
            </form>
        </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Informations</h2>
            <div class="space-y-3 text-sm text-slate-600">
                <div><strong>Nom:</strong> {{ etiquette.nom }}</div>
                <div>
                    <strong>Couleur:</strong>
                    <span class="ml-3 inline-flex rounded-full px-3 py-1 text-sm font-semibold text-white" style="background-color: {{ etiquette.couleur }};">
                        {{ etiquette.couleur }}
                    </span>
                </div>
                <div><strong>Utilisée par:</strong> {{ etiquette.taches|length }} tâche(s)</div>
            </div>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Aperçu</h2>
            <div class="flex items-center gap-4">
                <span class="inline-flex rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white" style="background-color: {{ etiquette.couleur }};">{{ etiquette.nom }}</span>
            </div>
        </div>
    </div>

    {% if etiquette.taches|length > 0 %}
        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900 mb-4">Tâches utilisant cette étiquette</h2>
            <div class="space-y-3">
                {% for tache in etiquette.taches %}
                    <a href="{{ path('projet_show', {id: tache.projet.id}) }}" class="block rounded-3xl border border-slate-200 bg-slate-50 p-4 transition hover:border-blue-200 hover:bg-white">
                        <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                            <div>
                                <h3 class="text-base font-semibold text-slate-900">{{ tache.titre }}</h3>
                                <p class="mt-1 text-sm text-slate-500">{{ tache.description|length > 100 ? tache.description|slice(0, 100) ~ '...' : tache.description }}</p>
                            </div>
                            <div class="text-sm text-slate-500">{{ tache.projet.nom }}</div>
                        </div>
                        <div class="mt-3 text-sm text-slate-500">
                            Statut: {{ tache.statut|replace({'a_faire': 'À faire', 'en_cours': 'En cours', 'terminee': 'Terminée'}) }} | Priorité: {{ tache.priorite|replace({'basse': 'Basse', 'moyenne': 'Moyenne', 'haute': 'Haute', 'urgente': 'Urgente'}) }}
                        </div>
                    </a>
                {% endfor %}
            </div>
        </section>
    {% endif %}

    <div>
        <a href="{{ path('etiquette_index') }}" class="inline-flex items-center rounded-full border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
            <i class="bi bi-arrow-left mr-2"></i> Retour à la liste
        </a>
    </div>
</div>
{% endblock %}
