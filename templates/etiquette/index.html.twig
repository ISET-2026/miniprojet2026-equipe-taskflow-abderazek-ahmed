{% extends 'base.html.twig' %}

{% block title %}Étiquettes - TaskFlow{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-tags"></i> Gestion des Étiquettes</h1>
    <a href="{{ path('etiquette_new') }}" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Nouvelle étiquette
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Couleur</th>
                <th>Nom</th>
                <th>Utilisée par (tâches)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for etiquette in etiquettes %}
                <tr>
                    <td>
                        <span class="badge" style="background-color: {{ etiquette.couleur }}; color: #fff; min-width: 80px;">
                            &nbsp;&nbsp;&nbsp;
                        </span>
                        <small class="ms-2">{{ etiquette.couleur }}</small>
                    </td>
                    <td><strong>{{ etiquette.nom }}</strong></td>
                    <td>{{ etiquette.taches|length }} tâche(s)</td>
                    <td>
                        <a href="{{ path('etiquette_edit', {id: etiquette.id}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form method="post" action="{{ path('etiquette_delete', {id: etiquette.id}) }}" style="display: inline;" data-confirm data-confirm-message="Supprimer cette étiquette ?">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ etiquette.id) }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                        <p class="mt-2">Aucune étiquette.</p>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
