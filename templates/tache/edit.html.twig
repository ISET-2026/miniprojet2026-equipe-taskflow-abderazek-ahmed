{% extends 'base.html.twig' %}

{% block title %}Modifier Tâche - TaskFlow{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <h2 class="card-title mb-4">
                    <i class="bi bi-pencil-square"></i> Modifier la tâche
                </h2>

                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
                    {{ form_row(form.titre) }}
                    {{ form_row(form.description) }}
                    {{ form_row(form.priorite) }}
                    {{ form_row(form.dateEcheance) }}
                    {{ form_row(form.assigneA) }}
                    {{ form_row(form.etiquettes) }}

                    <div class="mb-3">
                        {{ form_label(form.pieceJointe) }}
                        {% if tache.pieceJointeName %}
                            <div class="mb-2">
                                <a href="{{ asset('uploads/taches/' ~ tache.pieceJointeName) }}" target="_blank" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-download"></i> Voir le fichier actuel
                                </a>
                            </div>
                        {% endif %}
                        {{ form_widget(form.pieceJointe, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.pieceJointe) }}
                        <small class="form-text text-muted">Laissez vide pour conserver le fichier existant</small>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="{{ path('projet_show', {id: tache.projet.id}) }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Annuler
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-save"></i> Enregistrer
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
