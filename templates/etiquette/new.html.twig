{% extends 'base.html.twig' %}

{% block title %}Nouvelle Étiquette - TaskFlow{% endblock %}

{% block body %}
<div class="grid min-h-[calc(100vh-7rem)] place-items-center py-10">
    <div class="w-full max-w-2xl rounded-[2rem] border border-slate-200 bg-white p-8 shadow-2xl">
        <div class="mb-6">
            <h2 class="text-3xl font-bold text-slate-900 mb-2"><i class="bi bi-tag-fill text-blue-600 mr-2"></i> Créer une étiquette</h2>
            <p class="text-slate-500">Ajoutez une couleur et un nom pour mieux organiser vos tâches.</p>
        </div>

        {{ form_start(form) }}
            <div class="space-y-5">
                <div>
                    {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                    {{ form_widget(form.nom, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                    {{ form_errors(form.nom) }}
                </div>

                <div>
                    {{ form_label(form.couleur, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                    {{ form_widget(form.couleur, {'attr': {'class': 'mt-2 h-14 w-20 rounded-3xl border border-slate-200 bg-slate-50 p-2 text-sm text-slate-900', 'style': 'height: 3.5rem;'}}) }}
                    {{ form_errors(form.couleur) }}
                    <p class="mt-2 text-sm text-slate-500">Choisissez une couleur (format #RRGGBB).</p>
                </div>

                <div class="flex flex-col gap-3 sm:flex-row sm:justify-between">
                    <a href="{{ path('etiquette_index') }}" class="inline-flex items-center justify-center rounded-full border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                        <i class="bi bi-arrow-left mr-2"></i> Annuler
                    </a>
                    <button type="submit" class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-emerald-600">
                        <i class="bi bi-check-circle mr-2"></i> Créer
                    </button>
                </div>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
