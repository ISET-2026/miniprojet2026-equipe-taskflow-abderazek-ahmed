{% extends 'base.html.twig' %}

{% block title %}Connexion - TaskFlow{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .login-submit-btn {
            display: inline-flex;
            width: 100%;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: #0f172a !important;
            color: #ffffff !important;
            padding: .75rem 1rem;
            font-size: .9rem;
            font-weight: 700;
            border: 1px solid #0f172a !important;
        }
        .login-submit-btn:hover {
            background: #1e293b !important;
            border-color: #1e293b !important;
        }
    </style>
{% endblock %}

{% block body %}
<div class="grid min-h-[calc(100vh-7rem)] place-items-center">
    <div class="w-full max-w-md rounded border border-slate-200 bg-white p-8 shadow-lg">
        <div class="text-center">
            <h3 class="text-2xl font-semibold text-slate-900"><i class="bi bi-box-arrow-in-right text-blue-600 mr-2"></i> Connexion</h3>
            <p class="mt-2 text-sm text-slate-500">Accédez à votre espace TaskFlow.</p>
        </div>

        {% if error %}
            {# Erreur affichée via SweetAlert2 #}
        {% endif %}

        <form method="post" action="{{ path('login') }}" class="mt-8 space-y-5">
            <div>
                <label for="inputEmail" class="block text-sm font-medium text-slate-700">Email</label>
                <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="mt-2 w-full rounded border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100" required autofocus>
            </div>

            <div>
                <label for="inputPassword" class="block text-sm font-medium text-slate-700">Mot de passe</label>
                <input type="password" name="password" id="inputPassword" class="mt-2 w-full rounded border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100" required>
            </div>

            <div class="flex items-center gap-2">
                <input type="checkbox" name="_remember_me" id="remember_me" class="h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500">
                <label class="text-sm text-slate-600" for="remember_me">Se souvenir de moi</label>
            </div>

            <button type="submit" class="login-submit-btn">
                <i class="bi bi-box-arrow-in-right mr-2"></i> Se connecter
            </button>
        </form>

        <div class="mt-6 border-t border-slate-200 pt-5 text-center text-sm text-slate-600">
            Pas encore de compte ? <a href="{{ path('app_register') }}" class="font-semibold text-blue-600 hover:text-blue-700">S'inscrire</a>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts_after %}
    {% if error %}
    <script type="module">
        import Swal from 'sweetalert2';
        Swal.fire({
            icon: 'error',
            title: 'Connexion impossible',
            text: {{ error.messageKey|trans(error.messageData, 'security')|json_encode|raw }}
        });
    </script>
    {% endif %}
{% endblock %}
