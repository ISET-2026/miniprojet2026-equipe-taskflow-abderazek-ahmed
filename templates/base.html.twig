<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}TaskFlow - Gestion de Projets{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📋</text></svg>">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
        <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@400;500;700&display=swap" rel="stylesheet">

        {% block stylesheets %}
            <style>
                :root {
                    --color-planifie: #3498db;
                    --color-en-cours: #f1c40f;
                    --color-termine: #2ecc71;
                    --color-annule: #e74c3c;
                    --color-basse: #3498db;
                    --color-moyenne: #2ecc71;
                    --color-haute: #e67e22;
                    --color-urgente: #e74c3c;
                    --header-height: 76px;
                }
                .badge-planifie { background-color: var(--color-planifie); }
                .badge-en-cours { background-color: var(--color-en-cours); color: #000; }
                .badge-termine { background-color: var(--color-termine); }
                .badge-annule { background-color: var(--color-annule); }
                .badge-basse { background-color: var(--color-basse); }
                .badge-moyenne { background-color: var(--color-moyenne); color: #000; }
                .badge-haute { background-color: var(--color-haute); }
                .badge-urgente { background-color: var(--color-urgente); }
                html, body {
                    font-size: 16px;
                    line-height: 1.45;
                }
                body {
                    margin: 0;
                    background: #f9fafb;
                    color: #374151;
                    font-family: Inter, 'Roboto Slab', system-ui, sans-serif;
                    min-height: 100vh;
                    overflow-x: hidden;
                }
                h1, h2, h3 {
                    margin: 0;
                    color: #111827;
                    line-height: 1.2;
                }
                p {
                    margin: 0;
                }
                .main-nav {
                    background: #ffffff;
                    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.06);
                }
                .main-nav .container {
                    max-width: 1152px;
                    margin: 0 auto;
                }
                .main-nav .navbar {
                    display: flex !important;
                    align-items: center;
                    gap: .25rem;
                    margin: 0;
                    padding: 0;
                    list-style: none;
                }
                .main-nav .navbar a {
                    border-radius: 999px;
                    color: #334155;
                    font-weight: 600;
                    text-decoration: none;
                }
                .main-nav .navbar a:hover {
                    background: #f1f5f9;
                    color: #0f172a;
                }
                .nav-pill {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    padding: .55rem .95rem !important;
                    margin: .2rem 0;
                }
                .nav-pill-primary {
                    background: #0f172a;
                    color: #fff !important;
                }
                .nav-pill-primary:hover {
                    background: #1e293b !important;
                    color: #fff !important;
                }
                .nav-pill-outline {
                    border: 1px solid #cbd5e1;
                    background: #fff;
                }
                .nav-pill-outline:hover {
                    border-color: #94a3b8;
                }
                .main-content {
                    margin: 0 auto;
                    max-width: 1152px;
                    padding: calc(var(--header-height) + 1.75rem) 1.25rem 5rem;
                }
                .main-content > div {
                    display: flex;
                    flex-direction: column;
                    gap: 1.25rem;
                }
                .flash-alert {
                    border-radius: .75rem;
                    border: 1px solid rgba(229, 231, 235, 0.9);
                    background: white;
                    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
                    padding: 1rem 1.25rem;
                    margin-bottom: 1rem;
                }
                .main-content section,
                .main-content .rounded-\[2rem\],
                .main-content .rounded-3xl {
                    border-radius: 0.75rem !important;
                    border: 1px solid #e5e7eb !important;
                    background: #ffffff !important;
                    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.05);
                }
                .main-content input,
                .main-content select,
                .main-content textarea {
                    border-radius: 0.5rem !important;
                    border: 1px solid #d1d5db !important;
                    background: #fff !important;
                    color: #111827 !important;
                    padding: .65rem .8rem;
                    font-size: .95rem;
                }
                .main-content input:focus,
                .main-content select:focus,
                .main-content textarea:focus {
                    border-color: #2563eb !important;
                    outline: 2px solid #dbeafe !important;
                    outline-offset: 0;
                }
                .main-content button,
                .main-content .inline-flex {
                    transition: all .25s ease;
                }
                .main-content button {
                    border: 0;
                    border-radius: 999px;
                    cursor: pointer;
                    font-weight: 600;
                }
                .main-content table {
                    width: 100%;
                    border-collapse: collapse;
                    background: #fff;
                }
                .main-content thead {
                    background: #f8fafc;
                }
                .main-content th,
                .main-content td {
                    padding: .9rem .8rem;
                    border-bottom: 1px solid #e5e7eb;
                    text-align: left;
                    vertical-align: middle;
                }
                .main-content th {
                    font-size: .78rem;
                    text-transform: uppercase;
                    letter-spacing: .04em;
                    color: #64748b;
                    font-weight: 700;
                }
                .main-content td {
                    color: #1f2937;
                    font-size: .92rem;
                }
                .main-content a {
                    text-decoration: none;
                }
                footer {
                    margin-top: 2rem;
                }
                @media (min-width: 1024px) {
                    :root {
                        --header-height: 96px;
                    }
                }
            </style>
        {% endblock %}

        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
    </head>
    <body class="text-gray-700">
        <header class="fixed top-0 left-0 right-0 z-40">
            <nav class="main-nav bg-white/95 border-b border-gray-200 backdrop-blur-sm">
                <div class="container xl:max-w-6xl mx-auto px-4">
                    <div class="lg:flex lg:justify-between">
                        <div class="flex justify-between">
                            <a href="{{ path('projet_index') }}" class="text-2xl font-bold text-gray-900 flex items-center py-4 lg:py-0">
                                TaskFlow
                            </a>
                            <div class="flex flex-row items-center py-4 lg:py-0">
                                <div class="relative text-gray-900 hover:text-black block lg:hidden">
                                    <button type="button" class="menu-mobile block py-3 px-6 border-b-2 border-transparent">
                                        <span class="sr-only">Mobile menu</span>
                                        <svg class="open h-8 w-8" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                                        </svg>
                                        <svg xmlns="http://www.w3.org/2000/svg" class="close bi bi-x-lg h-8 w-8" viewBox="0 0 16 16">
                                            <path d="M13.854 2.146a.5.5 0 0 1 0 .708l-11 11a.5.5 0 0 1-.708-.708l11-11a.5.5 0 0 1 .708 0Z"></path>
                                            <path d="M2.146 2.146a.5.5 0 0 0 0 .708l11 11a.5.5 0 0 0 .708-.708l-11-11a.5.5 0 0 0-.708 0Z"></path>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="flex flex-row">
                            <ul class="navbar bg-white lg:bg-transparent w-full hidden text-center lg:text-left lg:flex lg:flex-row text-gray-900 text-sm items-center font-bold">
                                <li class="relative hover:text-black">
                                    <a href="{{ path('projet_index') }}" class="block py-3 lg:py-7 px-6 border-b-2 border-transparent nav-pill">Projets</a>
                                </li>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <li class="relative hover:text-black">
                                        <a href="{{ path('etiquette_index') }}" class="block py-3 lg:py-7 px-6 border-b-2 border-transparent nav-pill">Étiquettes</a>
                                    </li>
                                {% endif %}
                                {% if app.user %}
                                    <li class="relative">
                                        <span class="inline-block py-3 lg:py-7 px-6 text-gray-500">{{ app.user.pseudo }}</span>
                                    </li>
                                    <li class="relative hover:text-black">
                                        <a href="{{ path('logout') }}" class="block py-3 lg:py-7 px-6 border-b-2 border-transparent nav-pill nav-pill-primary">Déconnexion</a>
                                    </li>
                                {% else %}
                                    <li class="relative hover:text-black">
                                        <a href="{{ path('login') }}" class="block py-3 lg:py-7 px-6 border-b-2 border-transparent nav-pill nav-pill-primary">Se connecter</a>
                                    </li>
                                    <li class="relative hover:text-black">
                                        <a href="{{ path('app_register') }}" class="block py-3 lg:py-7 px-6 border-b-2 border-transparent nav-pill nav-pill-outline">Inscription</a>
                                    </li>
                                {% endif %}
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        <main id="content" class="main-content">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash-alert">
                        <div class="flex items-start justify-between gap-4">
                            <div class="text-sm text-slate-700">{{ message }}</div>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer class="bg-gray-50 text-gray-700 border-t border-gray-200">
            <div class="container xl:max-w-6xl mx-auto px-4 py-10">
                <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
                    <div>
                        <p class="text-lg font-semibold text-gray-900">TaskFlow</p>
                        <p class="mt-2 max-w-xl text-sm leading-6 text-gray-500">Gestion simplifiee de vos projets et taches </p>
                    </div>
                    
                </div>
            </div>
        </footer>

        <a href="#" class="back-top fixed p-4 rounded bg-gray-100 border border-gray-100 text-gray-500 right-4 bottom-4 hidden" aria-label="Scroll To Top">
            <svg width="1rem" height="1rem" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" d="M8 3.5a.5.5 0 01.5.5v9a.5.5 0 01-1 0V4a.5.5 0 01.5-.5z" clip-rule="evenodd"></path>
                <path fill-rule="evenodd" d="M7.646 2.646a.5.5 0 01.708 0l3 3a.5.5 0 01-.708.708L8 3.707 5.354 6.354a.5.5 0 11-.708-.708l3-3z" clip-rule="evenodd"></path>
            </svg>
        </a>

        {% block javascripts_after %}{% endblock %}
    </body>
</html>
