<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}TaskFlow - Gestion de Projets{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📋</text></svg>">

        {% block stylesheets %}
            <!-- Bootstrap 5 CSS -->
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
            <!-- Bootstrap Icons -->
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
            <style>
                :root {
                    --color-planifie: #3498db;
                    --color-en-cours: #f1c40f;
                    --color-termine: #2ecc71;
                    --color-annule: #e74c3c;
                    --color-basse: #3498db;
                    --color-moyenne: #2ecc71;
                    --color-haute: #e67e22;
                    --color-urgente: #e74c3c;
                }
                .badge-planifie { background-color: var(--color-planifie); }
                .badge-en-cours { background-color: var(--color-en-cours); color: #000; }
                .badge-termine { background-color: var(--color-termine); }
                .badge-annule { background-color: var(--color-annule); }
                .badge-basse { background-color: var(--color-basse); }
                .badge-moyenne { background-color: var(--color-moyenne); color: #000; }
                .badge-haute { background-color: var(--color-haute); }
                .badge-urgente { background-color: var(--color-urgente); }
                body { padding-top: 70px; }
                .sidebar { position: fixed; top: 70px; right: 0; width: 300px; bottom: 0; background: #f8f9fa; padding: 20px; overflow-y: auto; }
                .main-content { margin-right: 320px; }
                @media (max-width: 768px) {
                    .sidebar { display: none; }
                    .main-content { margin-right: 0; }
                }
            </style>
        {% endblock %}

        {% block javascripts %}
            {{ importmap('app') }}
            <!-- Bootstrap JS -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        {% endblock %}
    </head>
    <body>
        <!-- Navigation -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
            <div class="container">
                <a class="navbar-brand" href="{{ path('projet_index') }}">
                    <i class="bi bi-check2-square"></i> TaskFlow
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('projet_index') }}">Projets</a>
                        </li>
                        {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('etiquette_index') }}">Étiquettes</a>
                        </li>
                        {% endif %}
                    </ul>
                    <ul class="navbar-nav">
                        {% if app.user %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i> {{ app.user.pseudo }}
                                </a>
                                <ul class="dropdown-menu">
                                    <li><span class="dropdown-item-text">{{ app.user.email }}</span></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" href="{{ path('logout') }}">
                                            <i class="bi bi-box-arrow-right"></i> Déconnexion
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('login') }}">Connexion</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_register') }}">Inscription</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="container main-content mt-4">
            <!-- Flash Messages -->
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>

        <!-- Footer -->
        <footer class="bg-dark text-light py-4 mt-5">
            <div class="container">
                <div class="row">
                    <div class="col-md-6">
                        <h5>TaskFlow</h5>
                        <p class="text-muted small">Application de gestion de tâches collaboratives</p>
                    </div>
                    <div class="col-md-6 text-end">
                        <p class="text-muted small">
                            &copy; {{ 'now'|date('Y') }} TaskFlow. Tous droits réservés.
                        </p>
                    </div>
                </div>
            </div>
        </footer>

        {% block javascripts_after %}
            {# SweetAlert2 will be loaded via importmap #}
        {% endblock %}
    </body>
</html>
