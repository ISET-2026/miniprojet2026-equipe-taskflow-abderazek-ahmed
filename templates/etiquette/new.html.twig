{% extends 'base.html.twig' %}

{% block title %}Nouvelle Étiquette - TaskFlow{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <h2 class="card-title mb-4">
                    <i class="bi bi-tag-fill"></i> Créer une étiquette
                </h2>

                {{ form_start(form) }}
                    <div class="mb-3">
                        {{ form_label(form.nom) }}
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.nom) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.couleur) }}
                        {{ form_widget(form.couleur, {'attr': {'class': 'form-control', 'type': 'color', 'style': 'height: 50px;'}}) }}
                        {{ form_errors(form.couleur) }}
                        <small class="form-text text-muted">Choisissez une couleur (format #RRGGBB)</small>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="{{ path('etiquette_index') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Annuler
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Créer
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
