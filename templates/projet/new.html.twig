{% extends 'base.html.twig' %}

{% block title %}Nouveau Projet - TaskFlow{% endblock %}

{% block body %}
<div class="grid min-h-[calc(100vh-7rem)] place-items-center py-10">
    <div class="w-full max-w-3xl rounded-[2rem] border border-slate-200 bg-white p-8 shadow-2xl">
        <div class="mb-8">
            <h2 class="text-3xl font-bold text-slate-900 mb-2"><i class="bi bi-plus-circle-fill text-blue-600 mr-2"></i> Créer un nouveau projet</h2>
            <p class="text-slate-500">Ajoutez un projet et commencez à organiser votre équipe efficacement.</p>
        </div>

        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
            <div class="space-y-5">
                <div>
                    {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                    {{ form_widget(form.nom, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                    {{ form_errors(form.nom) }}
                </div>

                <div>
                    {{ form_label(form.description, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                    {{ form_widget(form.description, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100', 'rows': 4}}) }}
                    {{ form_errors(form.description) }}
                </div>

                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        {{ form_label(form.dateLimite, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                        {{ form_widget(form.dateLimite, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                        {{ form_errors(form.dateLimite) }}
                    </div>
                    <div>
                        {{ form_label(form.statut, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                        {{ form_widget(form.statut, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                        {{ form_errors(form.statut) }}
                    </div>
                </div>

                <div>
                    {{ form_label(form.image, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                    {{ form_widget(form.image, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900'}}) }}
                    {{ form_errors(form.image) }}
                    <p class="mt-2 text-sm text-slate-500">Formats acceptés : JPEG, PNG, WebP (max 2 Mo)</p>
                </div>

                <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center">
                    <a href="{{ path('projet_index') }}" class="btn-taskflow-outline order-2 sm:order-1">
                        <i class="bi bi-arrow-left mr-2" aria-hidden="true"></i>Retour aux projets
                    </a>
                    <button type="submit" class="btn btn-primary btn-taskflow-primary order-1 sm:order-2 w-full sm:w-auto justify-center">
                        <i class="bi bi-check-circle mr-2" aria-hidden="true"></i>Créer le projet
                    </button>
                </div>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
