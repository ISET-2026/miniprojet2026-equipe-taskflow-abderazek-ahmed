{% extends 'base.html.twig' %}

{% block title %}Inscription - TaskFlow{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .register-submit-btn {
            display: inline-flex;
            width: 100%;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: #2563eb !important;
            color: #ffffff !important;
            padding: .75rem 1rem;
            font-size: .9rem;
            font-weight: 700;
            border: 1px solid #2563eb !important;
        }
        .register-submit-btn:hover {
            background: #1d4ed8 !important;
            border-color: #1d4ed8 !important;
        }
    </style>
{% endblock %}

{% block body %}
<div class="grid min-h-[calc(100vh-7rem)] place-items-center">
    <div class="w-full max-w-md rounded border border-slate-200 bg-white p-8 shadow-lg">
        <div class="text-center">
            <h3 class="text-2xl font-semibold text-slate-900"><i class="bi bi-person-plus text-blue-600 mr-2"></i> Créer un compte</h3>
            <p class="mt-2 text-sm text-slate-500">Rejoignez TaskFlow pour gérer vos projets en équipe.</p>
        </div>

        {{ form_start(registrationForm, {'attr': {'class': 'mt-8 space-y-5'}}) }}
            <div>
                {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(registrationForm.email, {'attr': {'class': 'mt-2 w-full rounded border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                {{ form_errors(registrationForm.email) }}
            </div>

            <div>
                {{ form_label(registrationForm.pseudo, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(registrationForm.pseudo, {'attr': {'class': 'mt-2 w-full rounded border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                {{ form_errors(registrationForm.pseudo) }}
            </div>

            <div>
                {{ form_label(registrationForm.accountType, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                <div class="mt-2 space-y-3">
                    {{ form_widget(registrationForm.accountType, {'attr': {'class': 'flex flex-col gap-2'}}) }}
                </div>
                {{ form_errors(registrationForm.accountType) }}
            </div>

            <div>
                {{ form_label(registrationForm.plainPassword.first, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'mt-2 w-full rounded border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                {{ form_errors(registrationForm.plainPassword.first) }}
            </div>

            <div>
                {{ form_label(registrationForm.plainPassword.second, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-700'}}) }}
                {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'mt-2 w-full rounded border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                {{ form_errors(registrationForm.plainPassword.second) }}
            </div>

            <button type="submit" class="register-submit-btn">
                <i class="bi bi-check-circle mr-2"></i> S'inscrire
            </button>
        {{ form_end(registrationForm) }}

        <div class="mt-6 border-t border-slate-200 pt-5 text-center text-sm text-slate-600">
            Déjà inscrit ? <a href="{{ path('login') }}" class="font-semibold text-blue-600 hover:text-blue-700">Se connecter</a>
        </div>
    </div>
</div>
{% endblock %}
