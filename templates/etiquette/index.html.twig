{% extends 'base.html.twig' %}

{% block title %}Étiquettes - TaskFlow{% endblock %}

{% block body %}
<div class="space-y-6">
    <div class="etiquette-toolbar">
        <div>
            <h1 class="etiquette-page-title"><i class="bi bi-tags text-blue-600 mr-2"></i>Étiquettes</h1>
            <p class="etiquette-page-sub">Créez des étiquettes colorées pour classer vos tâches dans les projets.</p>
        </div>
        <a href="{{ path('etiquette_new') }}" class="btn-taskflow-primary" title="Ajouter une étiquette">
            <i class="bi bi-plus-circle" aria-hidden="true"></i>
            Nouvelle étiquette
        </a>
    </div>

    <section class="etiquette-card">
        {% if etiquettes|length > 0 %}
            <div class="overflow-x-auto">
                <table class="etiquette-table min-w-full divide-y divide-slate-200 text-sm text-slate-700">
                    <thead class="text-left text-xs uppercase tracking-[0.08em]">
                        <tr>
                            <th class="px-4 py-3">Couleur</th>
                            <th class="px-4 py-3">Nom</th>
                            <th class="px-4 py-3">Utilisée par</th>
                            <th class="px-4 py-3 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 bg-white">
                        {% for etiquette in etiquettes %}
                            <tr class="hover:bg-slate-50">
                                <td class="px-4 py-4 align-middle">
                                    <div class="flex items-center gap-3">
                                        <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full ring-2 ring-slate-200" style="background-color: {{ etiquette.couleur }};" title="{{ etiquette.couleur }}"></span>
                                        <span class="text-sm font-mono text-slate-600">{{ etiquette.couleur }}</span>
                                    </div>
                                </td>
                                <td class="px-4 py-4 align-middle font-semibold text-slate-900">{{ etiquette.nom }}</td>
                                <td class="px-4 py-4 align-middle text-slate-600">{{ etiquette.taches|length }} tâche(s)</td>
                                <td class="px-4 py-4 align-middle text-right">
                                    <form method="post" action="{{ path('etiquette_delete', {id: etiquette.id}) }}" class="inline" data-confirm data-confirm-message="Supprimer cette étiquette ?">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ etiquette.id) }}">
                                        <button type="submit" class="btn-taskflow-danger">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                            Supprimer
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="flex flex-col items-center justify-center gap-4 px-8 py-14 text-center text-slate-500">
                <i class="bi bi-inbox text-4xl" aria-hidden="true"></i>
                <p class="text-sm">Aucune étiquette pour l’instant. Utilisez le bouton ci-dessus pour en créer une.</p>
                <a href="{{ path('etiquette_new') }}" class="btn-taskflow-primary">
                    <i class="bi bi-plus-circle" aria-hidden="true"></i>
                    Créer une étiquette
                </a>
            </div>
        {% endif %}
    </section>
</div>
{% endblock %}
