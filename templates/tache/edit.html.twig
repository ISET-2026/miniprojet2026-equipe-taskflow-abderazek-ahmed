{% extends 'base.html.twig' %}

{% block title %}Modifier Tâche - TaskFlow{% endblock %}

{% block body %}
<div class="grid min-h-[calc(100vh-7rem)] place-items-center py-10">
    <div class="w-full max-w-3xl rounded-[2rem] border border-slate-200 bg-white p-8 shadow-2xl">
        <div class="mb-6">
            <h2 class="text-3xl font-bold text-slate-900 mb-2"><i class="bi bi-pencil-square text-blue-600 mr-2"></i> Modifier la tâche</h2>
            <p class="text-slate-500">Mettez à jour les détails de cette tâche et ajustez son assignation si besoin.</p>
        </div>

        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
            <div class="space-y-5">
                <div>
                    {{ form_label(form.titre, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                    {{ form_widget(form.titre, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                    {{ form_errors(form.titre) }}
                </div>

                <div>
                    {{ form_label(form.description, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                    {{ form_widget(form.description, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100', 'rows': 4}}) }}
                    {{ form_errors(form.description) }}
                </div>

                <div class="grid gap-4 md:grid-cols-3">
                    <div>
                        {{ form_label(form.priorite, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                        {{ form_widget(form.priorite, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                        {{ form_errors(form.priorite) }}
                    </div>
                    <div>
                        {{ form_label(form.statut, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                        {{ form_widget(form.statut, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                        {{ form_errors(form.statut) }}
                    </div>
                    <div>
                        {{ form_label(form.dateEcheance, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                        {{ form_widget(form.dateEcheance, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                        {{ form_errors(form.dateEcheance) }}
                    </div>
                </div>

                <div>
                    {{ form_label(form.assigneA, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                    {% if not can_assign_tasks %}
                        <p class="mt-2 text-sm text-slate-500">Seul le propriétaire du projet peut modifier l’assignation.</p>
                    {% endif %}
                    {{ form_widget(form.assigneA, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                    {{ form_errors(form.assigneA) }}
                </div>

                <div>
                    {{ form_label(form.etiquettes, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                    {{ form_widget(form.etiquettes, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100'}}) }}
                    {{ form_errors(form.etiquettes) }}
                </div>

                <div>
                    {{ form_label(form.pieceJointe, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700'}}) }}
                    {% if tache.pieceJointeName %}
                        <div class="mb-3">
                            <a href="{{ asset('uploads/taches/' ~ tache.pieceJointeName) }}" target="_blank" class="inline-flex items-center rounded-full border border-blue-200 bg-white px-4 py-2 text-sm font-semibold text-blue-700 transition hover:bg-blue-50">
                                <i class="bi bi-download mr-1"></i> Voir le fichier actuel
                            </a>
                        </div>
                    {% endif %}
                    {{ form_widget(form.pieceJointe, {'attr': {'class': 'mt-2 w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900'}}) }}
                    {{ form_errors(form.pieceJointe) }}
                    <p class="mt-2 text-sm text-slate-500">Laissez vide pour conserver le fichier existant.</p>
                </div>

                <div class="flex flex-col gap-3 sm:flex-row sm:justify-between">
                    <a href="{{ path('projet_show', {id: tache.projet.id}) }}" class="inline-flex items-center justify-center rounded-full border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                        <i class="bi bi-arrow-left mr-2"></i> Annuler
                    </a>
                    <button type="submit" class="inline-flex items-center justify-center rounded-full bg-amber-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-amber-600">
                        <i class="bi bi-save mr-2"></i> Enregistrer
                    </button>
                </div>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
