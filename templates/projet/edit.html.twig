{% extends 'base.html.twig' %}

{% block title %}Modifier Projet - TaskFlow{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <h2 class="card-title mb-4">
                    <i class="bi bi-pencil-square"></i> Modifier le projet
                </h2>

                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
                    {{ form_row(form.nom) }}
                    {{ form_row(form.description) }}
                    {{ form_row(form.dateLimite) }}
                    {{ form_row(form.statut) }}

                    <div class="mb-3">
                        {{ form_label(form.image) }}
                        {% if projet.imageName %}
                            <div class="mb-2">
                                <img src="{{ asset('images/projets/' ~ projet.imageName) }}" alt="Image actuelle" style="width: 100px; height: 100px; object-fit: cover; border-radius: 4px;">
                                <p class="form-text text-muted">Image actuelle</p>
                            </div>
                        {% endif %}
                        {{ form_widget(form.image, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.image) }}
                        <small class="form-text text-muted">Laissez vide pour conserver l'image existante</small>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="{{ path('projet_show', {id: projet.id}) }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Annuler
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-save"></i> Enregistrer
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
